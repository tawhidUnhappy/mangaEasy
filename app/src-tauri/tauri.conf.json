{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mangaEasy",
  "version": "0.9.26",
  "identifier": "com.mangaeasy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "mangaEasy",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/uv"],
    "windows": {
      "nsis": { "installMode": "both", "displayLanguageSelector": false },
      "wix": { "language": "en-US" }
    },
    "macOS": {
      "entitlements": null,
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": { "depends": [] },
      "rpm": { "depends": [] },
      "appimage": { "bundleMediaFramework": false }
    },
    "createUpdaterArtifacts": false
  }
}
