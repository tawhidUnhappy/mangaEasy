# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Build / env
.venv/
/dist/
/build/
build-tmp/
*.egg-info/

# Local config (publish the *.example.json files instead)
config.json
config.system.json

# Caches
/.cache/
/.hf_cache/
.pytest_cache/
.ruff_cache/

# This install's self-contained data: AI tool envs, app state, HF/torch/uv caches
/.mangaeasy/

# Generated runtime output
/tmp/
/tmp_video/
/videos/
/output_videos/
/audio/
/audio_faded/
/output/
/work/
/audio_preprocessed/
/download_logs/
*.log
*.err
*.out

# User content and local media
/library/
/manga/
/static/
/templates/
/prompts/
/music/*
!/music/
!/music/Thapin_by_the_sea.wav
/fonts/
/background_image/
/vocal/*
!/vocal/
!/vocal/manga_vocal2.wav
/upscale/
/thumbnail/

# External AI tools are sibling uv projects, not vendored here
/kokoro-82m/
/index-tts/
/magi-v3/
/deepseek-ocr2/
/z-image-turbo/

# Isolated dev tooling (e.g. portable Node.js) — not vendored, not global
/.tools/

# Electron desktop app — node_modules + build output, not the app's source
desktop/node_modules/
desktop/out/
desktop/dist/

# PyInstaller-built Python backend, copied in fresh by CI/bootstrap before
# electron-builder runs — not source, rebuilt from packaging/mangaeasy.spec
/desktop/resources/backend/

# Editor / assistant local state
.claude/
.idea/
.vscode/

# eslint cache
desktop/.eslintcache
