{
  "_comment": "Copy to config.system.json and tune for your machine/project.",
  "download_defaults": {
    "translated_language": "en",
    "use_data_saver": false,
    "download_delay": 0.5
  },
  "bgm": {
    "file": "music/Thapin_by_the_sea.wav",
    "volume_db": -26
  },
  "video": {
    "width": 1920,
    "height": 1080,
    "fps": 24,
    "background_style": "blur",
    "blur_backend": "auto",
    "blur_downscale": 4,
    "blur_sigma": 28.0,
    "background_brightness": -0.06,
    "background_saturation": 1.08,
    "background_image": "background_image/BACKGROUND.png",
    "encoder": {
      "nvenc_cq": 19,
      "nvenc_preset": "p6",
      "libx264_crf": 18,
      "libx264_preset": "slow",
      "aac_bitrate": "256k",
      "bgm_bitrate": "192k"
    }
  },
  "audio": {
    "sample_rate": 48000,
    "channels": 1,
    "fade_in_ms": 15,
    "fade_out_ms": 220,
    "tail_silence_ms": 80
  },
  "paths": {
    "library_subdir": "library",
    "panels_subdir": "panels",
    "audio_subdir": "audio",
    "processed_subdir": "panels_processed"
  },
  "process_panels": {
    "upscale": false,
    "upscale_factor": 4,
    "mirror": false,
    "hide_bubbles": false,
    "inpaint_radius": 5
  },
  "watermark": {
    "enabled": false,
    "text": "MyChannel",
    "opacity": 0.55,
    "font_size": 48,
    "padding": 20
  },
  "whisper": {
    "model": "medium",
    "device": "auto",
    "compute": "float16"
  },
  "tts": {
    "engine": "indextts",
    "speaker_wav": "vocal/manga_vocal2.wav",
    "use_raw_narration": true
  },
  "cut_page": {
    "reading_direction": "rtl"
  }
}
